<?xml version="1.0" encoding="utf-8"?>
<!--
    FinanceGuardian AI — Fullscreen Warning Overlay
    Rendered via TYPE_ACCESSIBILITY_OVERLAY (no SYSTEM_ALERT_WINDOW needed)
    Root is a FrameLayout so the neon border canvas sits behind the card.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true">

    <!-- ── Neon border canvas (drawn in WarningOverlay.kt via Paint) ── -->
    <com.example.financeguardian.NeonBorderView
        android:id="@+id/neonBorder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Center warning card ── -->
    <LinearLayout
        android:id="@+id/warningCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:background="@drawable/bg_warning_card"
        android:orientation="vertical"
        android:padding="28dp"
        android:elevation="12dp">

        <!-- Warning icon + headline row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/iconWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:text="⚠"
                android:textColor="#FF3D5A"
                android:textSize="36sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="IMPULSE DETECTED"
                android:textColor="#F0F4FF"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Neon divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/divider_neon" />

        <!-- AI label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_ai_badge"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="🦞  OpenClaw AI Intervention"
            android:textColor="#00C2FF"
            android:textSize="11sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="14dp" />

        <!-- Dynamic warning message from backend -->
        <TextView
            android:id="@+id/tvWarningMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="This purchase may hurt your financial goals."
            android:textColor="#C8D0E8"
            android:textSize="15sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="20dp" />

        <!-- Amount row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_amount_pill"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="Flagged amount  "
                android:textColor="#6B7A99"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="₹0"
                android:textColor="#FF3D5A"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="24dp" />

        <!-- Auto-dismiss progress bar -->
        <ProgressBar
            android:id="@+id/dismissProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@drawable/progress_neon"
            android:indeterminate="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="Auto-dismissing in 4 seconds…"
            android:textColor="#3D4A66"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>