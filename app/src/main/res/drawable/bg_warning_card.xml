<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_warning_card.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Red glow shadow layer -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1AFF3D5A" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Red stroke border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0F1520" />
            <stroke
                android:width="1.5dp"
                android:color="#66FF3D5A" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>